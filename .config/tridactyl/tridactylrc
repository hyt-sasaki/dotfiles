" === コマンド設定 ===
" --- pocket ---
command get_latest_pocket exclaim_quiet zsh -c "/usr/local/bin/pockyt get -n 1 -f '{title}' | pbcopy"
" --- choosy ---
command choosy composite js 'x-choosy://open/' + document.location.href | open
" --- TST ---
command connectTst jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` });
command collapseCurrentTab jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'collapse-tree', tab:  'current' });
command expandCurrentTab jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'expand-tree', tab:  'current' });
command focusRootTab jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'focus', tab:  'root' });
command focusParentTab jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'focus', tab:  'parent' });
command focusLastDescendantTab jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'focus', tab:  'lastDescendant' });
command closeTreeTabs jsb browser.runtime.sendMessage('treestyletab@piro.sakura.ne.jp', { type: 'get-tree', tab: 'current' }).then((tab) => {tab.children.forEach((child) => browser.tabs.remove(child.id)); browser.tabs.remove(tab.id)});
command nextTree jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'focus', tab:  'nextSibling' });
command previousTree jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'focus', tab:  'previousSibling' });
command moveCurrentTabToEnd jsb browser.runtime.connect('treestyletab@piro.sakura.ne.jp', { name: `connection from ${browser.runtime.id}` }).postMessage({ type: 'move-to-end', tab:  'current' });

